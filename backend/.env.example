# Get this from @BotFather on Telegram after creating your bot
BOT_TOKEN=your_bot_token_here

# Set this AFTER you deploy to Render — your Render service URL
# e.g. https://tg-video-player.onrender.com
PUBLIC_URL=

# Optional: your personal Telegram chat ID, so only you can add videos.
# Leave blank to allow anyone who finds the bot to add videos.
# Get your chat ID by messaging @userinfobot on Telegram.
ALLOWED_CHAT_ID=

PORT=3000
